{
  "openapi": "3.1.0",
  "info": {
    "title": "SYA Planning Function API",
    "version": "0.1.0",
    "description": "Cognitive-aware dynamic task decomposition and rolling-wave planning API for the SYA platform."
  },
  "servers": [
    {
      "url": "http://localhost:{port}",
      "description": "Local SYA function runtime. The Electron host assigns the port dynamically.",
      "variables": {
        "port": {
          "default": "0"
        }
      }
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "operationId": "health",
        "summary": "Planning function health check",
        "responses": {
          "200": {
            "description": "Runtime is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FunctionResponse"
                },
                "example": {
                  "ok": true,
                  "data": {
                    "status": "ok",
                    "functionId": "planning",
                    "version": "0.1.0"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/manifest": {
      "get": {
        "operationId": "manifest",
        "summary": "Planning function manifest",
        "responses": {
          "200": {
            "description": "Function manifest with capabilities, events, and permissions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/planning/actions": {
      "get": {
        "operationId": "actions.list",
        "summary": "List callable Function API actions",
        "responses": {
          "200": {
            "description": "Action list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FunctionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/planning/config": {
      "get": {
        "operationId": "config.get",
        "summary": "Get current planning configuration",
        "responses": {
          "200": {
            "description": "Runtime configuration without secrets",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FunctionResponse"
                },
                "example": {
                  "ok": true,
                  "data": {
                    "planning": {
                      "completionLowThreshold": 0.6,
                      "completionHighThreshold": 0.9,
                      "evaluationLeafBatchSize": 3,
                      "metricsWindowSize": 10
                    },
                    "llm": {
                      "provider": "openai-compatible",
                      "model": "gpt-4o-mini",
                      "configured": false
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/planning/tasks/init": {
      "post": {
        "operationId": "tasks.init",
        "summary": "Initialize a cognitive planning run",
        "description": "Accepts a free-form goal and persona, publishes a NEW_TASK_REQUEST event, and asynchronously generates a task tree.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InitTaskRequest"
              },
              "example": {
                "goal": "Build an AI scheduling backend",
                "persona": "balanced"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Planning request accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FunctionResponse"
                },
                "example": {
                  "ok": true,
                  "data": {
                    "accepted": true,
                    "event_id": "8fd24f1a1e0f4e49b47f7e3c7f11d98e"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/planning/tasks/tree": {
      "get": {
        "operationId": "tasks.tree",
        "summary": "Get the current task tree snapshot",
        "description": "Returns `{ tree: null }` before the first planning run has completed.",
        "responses": {
          "200": {
            "description": "Current task tree snapshot or null",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FunctionResponse"
                },
                "example": {
                  "ok": true,
                  "data": {
                    "tree": {
                      "task_id": "root-demo",
                      "parent_id": null,
                      "title": "Build an AI scheduling backend",
                      "description": "Top-level plan",
                      "status": "PENDING",
                      "is_leaf": false,
                      "estimated_time": 8,
                      "actual_time": null,
                      "children": []
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/planning/tasks/status": {
      "post": {
        "operationId": "tasks.status.update",
        "summary": "Update a task node status",
        "description": "Function API status update endpoint without URL path parameters. The mutation is processed asynchronously through the event bus.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskStatusUpdateRequest"
              },
              "example": {
                "taskId": "root-demo-a",
                "status": "DONE",
                "actualTime": 1.2
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status update accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FunctionResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FunctionResponse": {
        "type": "object",
        "required": ["ok"],
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "data": {},
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" },
              "details": {}
            }
          }
        }
      },
      "InitTaskRequest": {
        "type": "object",
        "required": ["goal"],
        "additionalProperties": false,
        "properties": {
          "goal": {
            "type": "string",
            "minLength": 1
          },
          "persona": {
            "type": "string",
            "default": "balanced",
            "enum": ["balanced", "micro", "macro"]
          }
        }
      },
      "TaskStatusUpdateRequest": {
        "type": "object",
        "required": ["taskId", "status"],
        "additionalProperties": false,
        "properties": {
          "taskId": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["PENDING", "IN_PROGRESS", "DONE", "BLOCKED", "SKIPPED"]
          },
          "actualTime": {
            "type": "number",
            "minimum": 0
          }
        }
      },
      "TaskNode": {
        "type": "object",
        "required": [
          "task_id",
          "parent_id",
          "title",
          "description",
          "status",
          "is_leaf",
          "estimated_time",
          "actual_time",
          "children"
        ],
        "properties": {
          "task_id": { "type": "string" },
          "parent_id": { "type": ["string", "null"] },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["PENDING", "IN_PROGRESS", "DONE", "BLOCKED", "SKIPPED"]
          },
          "is_leaf": { "type": "boolean" },
          "estimated_time": { "type": "number" },
          "actual_time": { "type": ["number", "null"] },
          "children": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaskNode"
            }
          }
        }
      }
    }
  }
}
